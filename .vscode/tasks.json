{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "运行当前 Python 文件",
            "type": "shell",
            "command": "cd '${fileDirname}' ; & '${workspaceFolder}\\.venv\\Scripts\\python.exe' '${file}'",
            "options": {
                "shell": {
                    "executable": "powershell.exe",
                    "args": ["-NoProfile", "-Command"]
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true,
                "clear": false
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
